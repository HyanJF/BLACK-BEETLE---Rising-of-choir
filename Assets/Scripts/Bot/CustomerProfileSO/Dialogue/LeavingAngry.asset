  m_Script: {fileID: 11500000, guid: b9eeef22f2cac9642aa674445df5d00b, type: 3}
  m_Name: LeavingAngry
  m_EditorClassIdentifier: Assembly-CSharp::DialogueCollectionSO
  type: 7
  dialogues:
  - "Esto fue una p\xE9rdida de tiempo."
  - No pienso volver.
  - "Qu\xE9 mal servicio."
  - Estoy muy decepcionado.
  - Me voy.
  - Ya tuve suficiente.
  - Esto fue inaceptable.
  - Esperaba algo mejor.
  - No vale la pena quedarse.
  - "Se acab\xF3 mi paciencia."
  - "Olv\xEDdalo."
  - "Buscar\xE9 otra taberna."
  - "Esto termin\xF3."
  - No vuelvas a hacerme esperar.
  - "Qu\xE9 desastre."
  - "Me retirar\xE9, horrible servicio."
  - "No era tan dif\xEDcil."
  - "No recib\xED lo que esperaba."
  - "Esto arruin\xF3 la visita.\r\n"
  - Estoy harto.
  - "Ya no quiero seguir aqu\xED.\r\n"
  - Has perdido un cliente.
  - "No volver\xE9 a confiar en este lugar."
  - "\xA1Me marcho!"
  - "Adi\xF3s... y suerte con los dem\xE1s."
